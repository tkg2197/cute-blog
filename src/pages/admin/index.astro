---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createServiceClient } from "../../lib/supabase";
import { ACTIVITY_CATEGORIES, ACTIVITY_CATEGORY_LABELS, ACTIVITY_PERIODS, MOOD_LABELS } from "../../lib/types";
import type { ActivityEntry, BlogPost, LifeRecord, Photo } from "../../lib/types";

const supabase = createServiceClient();
const user = Astro.locals.user!;

const [{ data: posts }, { data: photos }, { data: records }, { data: activities }] = await Promise.all([
  supabase
    .from("blog_posts")
    .select("id,slug,title,excerpt,tags,published_at,created_at,storage_path,profiles(display_name,author_key)")
    .eq("author_id", user.id)
    .order("created_at", { ascending: false }),
  supabase
    .from("photos")
    .select("id,title,caption,taken_on,storage_path,created_at,profiles(display_name,author_key)")
    .eq("owner_id", user.id)
    .order("created_at", { ascending: false }),
  supabase
    .from("life_records")
    .select("id,record_on,mood,body,created_at,updated_at,profiles(display_name,author_key)")
    .eq("owner_id", user.id)
    .order("record_on", { ascending: false })
    .order("created_at", { ascending: false }),
  supabase
    .from("activity_entries")
    .select("id,activity_on,period,category,minutes,body,created_at,updated_at,profiles(display_name,author_key)")
    .eq("owner_id", user.id)
    .order("activity_on", { ascending: false })
    .order("created_at", { ascending: false }),
]);

const myPosts = (posts || []) as BlogPost[];
const myRecords = (records || []) as LifeRecord[];
const myActivities = (activities || []) as ActivityEntry[];
const myPhotos = ((photos || []) as Photo[]).map((photo) => ({
  ...photo,
  publicUrl: supabase.storage.from("photos").getPublicUrl(photo.storage_path).data.publicUrl,
}));

const errorMessage = Astro.url.searchParams.get("error");
const uploaded = Astro.url.searchParams.get("uploaded");
const deleted = Astro.url.searchParams.get("deleted");
const created = Astro.url.searchParams.get("created");

const today = new Date().toISOString().slice(0, 10);
---

<BaseLayout title="Admin - Our Nest" current="admin" backHref="/?skipCover=1#home">
  <section class="page-title">
    <p class="kicker">Admin</p>
    <h1>What are we saving today?</h1>
    <p>Core tools for saving records, photos, activity entries, and Markdown posts.</p>
  </section>

  {errorMessage && <p class="notice error" style="margin-top:16px">{errorMessage}</p>}
  {uploaded === "photo" && <p class="notice" style="margin-top:16px">Photo uploaded.</p>}
  {created === "record" && <p class="notice" style="margin-top:16px">Record saved.</p>}
  {created === "activity" && <p class="notice" style="margin-top:16px">Activity saved.</p>}
  {deleted === "photo" && <p class="notice" style="margin-top:16px">Photo deleted.</p>}
  {deleted === "post" && <p class="notice" style="margin-top:16px">Post deleted.</p>}
  {deleted === "record" && <p class="notice" style="margin-top:16px">Record deleted.</p>}
  {deleted === "activity" && <p class="notice" style="margin-top:16px">Activity deleted.</p>}

  <section class="split split--wide-left" style="margin-top:24px">
    <div class="panel">
      <p class="kicker">Life Record</p>
      <h2>Write a record</h2>
      <form class="form-grid" action="/api/records/create" method="post" enctype="multipart/form-data">
        <div class="form-pair">
          <label class="field">
            <span>Date</span>
            <input name="record_on" type="date" value={today} required />
          </label>
          <label class="field">
            <span>Mood</span>
            <select name="mood" required>
              <option value="happy">Happy</option>
              <option value="loved">Loved</option>
              <option value="calm">Calm</option>
              <option value="tired">Tired</option>
              <option value="down">Low</option>
              <option value="moody">Moody</option>
            </select>
          </label>
        </div>
        <label class="field">
          <span>What happened today</span>
          <textarea name="body" rows="6" maxlength="800" placeholder="Write a small moment, feeling, or anything worth remembering." required></textarea>
        </label>
        <label class="field">
          <span>Photos (optional, multiple allowed)</span>
          <input name="photos" type="file" accept="image/*" multiple />
        </label>
        <button class="button" type="submit">Save record</button>
      </form>
    </div>

    <div class="panel">
      <p class="kicker">Photo Storage</p>
      <h2>Upload photo</h2>
      <form class="form-grid" action="/api/photos/upload" method="post" enctype="multipart/form-data">
        <label class="field">
          <span>Photo</span>
          <input name="photo" type="file" accept="image/*" required />
        </label>
        <label class="field">
          <span>Title</span>
          <input name="title" type="text" maxlength="80" placeholder="A small moment today" />
        </label>
        <label class="field">
          <span>Date</span>
          <input name="taken_on" type="date" />
        </label>
        <label class="field">
          <span>Caption</span>
          <textarea name="caption" rows="4" maxlength="240" placeholder="Write a little note about this photo"></textarea>
        </label>
        <button class="button" type="submit">Upload photo</button>
      </form>
    </div>
  </section>

  <section class="split" style="margin-top:24px">
    <div class="panel">
      <p class="kicker">Activity</p>
      <h2>Add activity</h2>
      <form class="form-grid" action="/api/activity/create" method="post">
        <div class="form-pair">
          <label class="field">
            <span>Date</span>
            <input name="activity_on" type="date" value={today} required />
          </label>
          <label class="field">
            <span>Period</span>
            <select name="period" required>
              {ACTIVITY_PERIODS.map((period) => (
                <option value={period.key}>{period.label} · {period.time}</option>
              ))}
            </select>
          </label>
        </div>
        <div class="form-pair">
          <label class="field">
            <span>Category</span>
            <select name="category" required>
              {ACTIVITY_CATEGORIES.map((category) => <option value={category}>{ACTIVITY_CATEGORY_LABELS[category] || category}</option>)}
            </select>
          </label>
          <label class="field">
            <span>Minutes</span>
            <input name="minutes" type="number" min="1" max="720" step="1" value="30" required />
          </label>
        </div>
        <label class="field">
          <span>What happened</span>
          <textarea name="body" rows="4" maxlength="180" placeholder="For example: sorted the photo wall and polished a few details" required></textarea>
        </label>
        <button class="button" type="submit">Save activity</button>
      </form>
    </div>

    <div class="panel">
      <p class="kicker">Markdown Blog</p>
      <h2>Upload post</h2>
      <form class="form-grid" action="/api/blog/upload" method="post" enctype="multipart/form-data">
        <label class="field">
          <span>Markdown file</span>
          <input name="markdown" type="file" accept=".md,text/markdown,text/plain" required />
        </label>
        <label class="field">
          <span>Custom slug (optional)</span>
          <input name="slug" type="text" maxlength="90" placeholder="our-first-post" />
        </label>
        <button class="button" type="submit">Upload post</button>
      </form>
      <p class="muted">Supports frontmatter: title, excerpt, tags. Separate tags with commas.</p>
    </div>

    <div class="panel">
      <div class="section-head">
        <div>
          <p class="kicker">Records</p>
          <h2>Manage records</h2>
        </div>
        <span class="count-pill">{myRecords.length} items</span>
      </div>
      <div class="manage-list">
        {myRecords.length ? myRecords.map((record) => (
          <article class="manage-item">
            <div class="manage-item__main">
              <h3>{record.record_on} · {MOOD_LABELS[record.mood] || record.mood}</h3>
              <p class="muted">{record.body}</p>
              <div class="meta">
                <span>{new Date(record.created_at).toLocaleDateString("zh-CN")}</span>
              </div>
            </div>
            <div class="manage-actions">
              <form action="/api/records/delete" method="post" data-confirm="Delete this record?" data-confirm-title="Delete record?">
                <input type="hidden" name="id" value={record.id} />
                <button class="mini-button mini-button--danger" type="submit">Delete</button>
              </form>
            </div>
          </article>
        )) : <p class="muted">No records yet.</p>}
      </div>
    </div>
  </section>

  <section class="split" style="margin-top:24px">
    <div class="panel">
      <div class="section-head">
        <div>
          <p class="kicker">Activity</p>
          <h2>Manage activity</h2>
        </div>
        <span class="count-pill">{myActivities.length} items</span>
      </div>
      <div class="manage-list">
        {myActivities.length ? myActivities.map((activity) => {
          const period = ACTIVITY_PERIODS.find((item) => item.key === activity.period);
          return (
            <article class="manage-item">
              <div class="manage-item__main">
                <h3>{activity.activity_on} · {period?.label || activity.period} · {ACTIVITY_CATEGORY_LABELS[activity.category] || activity.category}</h3>
                <p class="muted">{activity.body}</p>
                <div class="meta">
                  <span>{activity.minutes} min</span>
                  <span>{new Date(activity.created_at).toLocaleDateString("zh-CN")}</span>
                </div>
              </div>
              <div class="manage-actions">
                <form action="/api/activity/delete" method="post" data-confirm="Delete this activity record?" data-confirm-title="Delete activity?">
                  <input type="hidden" name="id" value={activity.id} />
                  <button class="mini-button mini-button--danger" type="submit">Delete</button>
                </form>
              </div>
            </article>
          );
        }) : <p class="muted">No activity records yet.</p>}
      </div>
    </div>

    <div class="panel">
      <p class="kicker">Quick Links</p>
      <h2>View stats</h2>
      <p class="muted">After saving activity records, open the Activity page to see the timeline, category split, and period overview.</p>
      <div class="action-row">
        <a class="button-secondary" href="/activity">Open Activity</a>
      </div>
    </div>
  </section>

  <section class="split" style="margin-top:24px">
    <div class="panel">
      <div class="section-head">
        <div>
          <p class="kicker">My Posts</p>
          <h2>Manage Markdown</h2>
        </div>
        <span class="count-pill">{myPosts.length} posts</span>
      </div>
      <div class="manage-list">
        {myPosts.length ? myPosts.map((post) => (
          <article class="manage-item">
            <div class="manage-item__main">
              <h3>{post.title}</h3>
              <p class="muted">{post.excerpt || "No excerpt"}</p>
              <div class="meta">
                <span>{new Date(post.published_at || post.created_at).toLocaleDateString("zh-CN")}</span>
                {(post.tags || []).map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <div class="manage-actions">
              <a class="mini-button" href={`/blog/${post.slug}`}>View</a>
              <form action="/api/blog/delete" method="post" data-confirm={`Delete "${post.title}"?`} data-confirm-title="Delete post?">
                <input type="hidden" name="id" value={post.id} />
                <button class="mini-button mini-button--danger" type="submit">Delete</button>
              </form>
            </div>
          </article>
        )) : <p class="muted">No posts uploaded yet.</p>}
      </div>
    </div>
    <div class="panel">
      <div class="section-head">
        <div>
          <p class="kicker">My Photos</p>
          <h2>Manage photos</h2>
        </div>
        <span class="count-pill">{myPhotos.length} photos</span>
      </div>
      <div class="manage-photo-grid">
        {myPhotos.length ? myPhotos.map((photo) => (
          <article class="card photo-card">
            <img src={photo.publicUrl} alt={photo.title || "Photo"} loading="lazy" />
            <div class="card-body">
              <strong>{photo.title || "Untitled photo"}</strong>
              <p class="muted">{photo.caption || ""}</p>
              <div class="meta">
                {photo.taken_on && <span>{photo.taken_on}</span>}
                <span>{new Date(photo.created_at).toLocaleDateString("zh-CN")}</span>
              </div>
              <form action="/api/photos/delete" method="post" data-confirm={`Delete "${photo.title || "this photo"}"?`} data-confirm-title="Delete photo?">
                <input type="hidden" name="id" value={photo.id} />
                <button class="mini-button mini-button--danger" type="submit">Delete photo</button>
              </form>
            </div>
          </article>
        )) : <p class="muted">No photos uploaded yet.</p>}
      </div>
    </div>
  </section>
</BaseLayout>
