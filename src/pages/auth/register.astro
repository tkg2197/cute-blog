---
import BaseLayout from "../../layouts/BaseLayout.astro";

const error = Astro.url.searchParams.get("error");
---

<BaseLayout title="Register - Our Nest" narrow backHref="/auth/login" backLabel="Back to login">
  <section class="page-title">
    <p class="kicker">Only two authors</p>
    <h1>Create a Nest Account</h1>
    <p>Each person registers one email and chooses an author identity. The database keeps one account for each identity.</p>
  </section>

  <section class="panel" style="margin-top:24px">
    {error && <p class="notice error">{error}</p>}
    <form class="form-grid" action="/api/auth/register" method="post">
      <label class="field">
        <span>Identity</span>
        <select name="author_key" required>
          <option value="white">White</option>
          <option value="brown">Brown</option>
        </select>
      </label>
      <label class="field">
        <span>Display name</span>
        <input name="display_name" type="text" maxlength="24" placeholder="For example: Jason" required />
      </label>
      <label class="field">
        <span>Email</span>
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <label class="field">
        <span>Password</span>
        <input name="password" type="password" autocomplete="new-password" minlength="6" required />
      </label>
      <button class="button" type="submit">Register</button>
    </form>
    <p class="muted">Already have an account? <a href="/auth/login">Log in</a></p>
  </section>
</BaseLayout>
