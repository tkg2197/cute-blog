---
import PrototypeLayout from "../layouts/PrototypeLayout.astro";
import { createServiceClient } from "../lib/supabase";
import { AUTHOR_LABELS } from "../lib/types";
import type { AuthorKey, BlogPost, Photo, Place, PlaceTone, Profile } from "../lib/types";

const user = Astro.locals.user;
const profile = Astro.locals.profile;
const authorKey = (profile?.author_key || "white") as AuthorKey;

const supabase = createServiceClient();

const [{ data: posts }, { data: photos }, { data: placeRows }] = await Promise.all([
  supabase
    .from("blog_posts")
    .select("id,slug,title,excerpt,tags,published_at,created_at,profiles(display_name,author_key)")
    .order("published_at", { ascending: false })
    .limit(3),
  supabase
    .from("photos")
    .select("id,title,caption,taken_on,storage_path,created_at,profiles(display_name,author_key)")
    .order("created_at", { ascending: false })
    .limit(5),
  supabase
    .from("places")
    .select("id,name,note,tone,created_at")
    .order("created_at", { ascending: false })
    .limit(3),
]);
const dbPlaces = (placeRows || []) as Place[];

const recentPosts = (posts || []) as BlogPost[];
const recentPhotos = ((photos || []) as Photo[]).map((photo) => ({
  ...photo,
  publicUrl: supabase.storage.from("photos").getPublicUrl(photo.storage_path).data.publicUrl,
}));
const photoFallbacks = [
  { publicUrl: "/assets/小白首页形象.png", title: "小白", caption: "", taken_on: "小白", profiles: { display_name: "白狗" } },
  { publicUrl: "/assets/小棕首页形象.jpg", title: "小棕", caption: "", taken_on: "小棕", profiles: { display_name: "棕狗" } },
  { publicUrl: "/assets/早晨-白狗.png", title: "早晨", caption: "", taken_on: "早晨", profiles: { display_name: "白狗" } },
  { publicUrl: "/assets/中午-棕狗.png", title: "中午", caption: "", taken_on: "中午", profiles: { display_name: "棕狗" } },
  { publicUrl: "/assets/晚上-白狗.png", title: "晚上", caption: "", taken_on: "晚上", profiles: { display_name: "白狗" } },
];
const displayPhotos = [...recentPhotos, ...photoFallbacks].slice(0, 5);
const { data: profileRows } = user
  ? await supabase
      .from("profiles")
      .select("id,email,author_key,display_name,created_at")
      .order("created_at", { ascending: true })
      .limit(2)
  : { data: [] };
const homeProfiles = (profileRows || []) as Profile[];
const brownDisplayName = user ? homeProfiles[0]?.display_name || "棕狗" : "棕狗";
const whiteDisplayName = user ? homeProfiles[1]?.display_name || "白狗" : "白狗";
const currentWeatherWho = user
  ? homeProfiles[0]?.id === user.id
    ? "brown"
    : homeProfiles[1]?.id === user.id
      ? "white"
      : profile?.author_key || ""
  : "";
const postFallbacks = [
  { href: "/blog", date: "2026.05.22", title: "把我们的小窝变成可以一起写下去的地方" },
  { href: "/photos", date: "2026.05.21", title: "照片墙、生活记录和时段活动的第一版" },
  { href: "/activity", date: "Today", title: "看看今天的不同时段都做了什么" },
];

const skipCoverOnLoad = Astro.url.searchParams.get("skipCover") === "1";
const placeFallbacks: Array<{ name: string; note: string; tone: PlaceTone }> = [
  { name: "京都", note: "想在傍晚慢慢走过小巷，找一家安静的店吃热乎乎的晚饭。", tone: "night" },
  { name: "大理", note: "去有风的地方，看湖面、云影和很慢很慢的下午。", tone: "desert" },
  { name: "冰岛", note: "一起等极光出现，把冷风和星星都记进今年的愿望里。", tone: "sea" },
];
const homePlaces = dbPlaces.length
  ? dbPlaces.map((p) => ({ name: p.name, note: p.note, tone: p.tone as PlaceTone }))
  : placeFallbacks;
const formatPostDate = (date: string) => new Date(date).toLocaleDateString("zh-CN").replaceAll("/", ".");
---

<PrototypeLayout
  title="我们的小窝"
  current="home"
  htmlClass="home-profile-root"
  bodyClass={skipCoverOnLoad ? "home-profile-page home-revealed" : "home-profile-page home-cover-open"}
  hideNav
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/styles.css" />
    <script is:inline>
      (function () {
        try {
          var params = new URLSearchParams(location.search);
          var hash = (location.hash || "").toLowerCase();
          var skipHome =
            params.get("skipCover") === "1" ||
            hash === "#home" ||
            hash === "#main" ||
            hash === "#skipcover";
          if (skipHome || localStorage.getItem("cuteblog.discoveryIntro.v1") === "1") {
            document.documentElement.classList.add("home-intro-seen");
          }
        } catch (e) {}
      })();
    </script>
  </Fragment>

  <section class="home-discovery" id="homeDiscoveryIntro" aria-label="进入小世界前的悄悄话">
    <div class="home-discovery__mist" aria-hidden="true"></div>
    <div class="home-discovery__content" aria-live="polite">
      <p class="home-discovery__line" id="discoveryLineOne"></p>
      <p class="home-discovery__line" id="discoveryLineTwo"></p>
    </div>
  </section>

  <section class="home-cover" id="homeCover" aria-label="首页封面">
    <img class="home-cover__bg" src="/assets/首页封面.png" alt="" />
    <canvas class="home-cover__petals" id="coverPetals" aria-hidden="true"></canvas>
    <div class="home-cover__shade" aria-hidden="true"></div>
    <div class="home-cover__content">
      <p class="home-cover__eyebrow">我们的小窝</p>
      <h1 class="home-cover__title">Welcome to our home</h1>
    </div>
    <button class="home-cover__button" id="exploreHome" type="button" aria-label="Start now">
      <span class="home-cover__button-text home-cover__button-text--top">Explore</span>
      <span class="home-cover__button-text home-cover__button-text--bottom">Start now</span>
    </button>
  </section>

  <div class="home-bg" aria-hidden="true">
    <div class="home-bg__layer" id="homeBg"></div>
    <div class="home-bg__wash"></div>
  </div>

  <header class="site-nav home-nav" data-site-nav>
    <div class="site-nav__bar">
      <a class="site-nav__brand home-nav__brand" href="/?skipCover=1#home">我们的小窝</a>
      <nav class="site-nav__links home-nav__links" aria-label="主页导航">
        <a class="is-active" href="/?skipCover=1#home" aria-current="page">首页</a>
        <a href="/places">今年想去</a>
        <a href="/blog">双人博客</a>
        <a href="/records">生活记录</a>
        <a href="/photos">照片墙</a>
        <a href="/activity">时段活动</a>
        {!user && (
          <a class="site-nav__auth-link" href="/auth/login">登录</a>
        )}
      </nav>
      {user && (
        <div class="site-nav__auth">
          <form action="/api/auth/logout" method="post">
            <span class={`auth-pill auth-pill--${authorKey}`} title={profile?.display_name || AUTHOR_LABELS[authorKey]}>{profile?.display_name || AUTHOR_LABELS[authorKey]}</span>
            <button class="auth-link" type="submit" aria-label="退出登录">退出</button>
          </form>
        </div>
      )}
    </div>
  </header>

  <main class="home-profile" id="home" data-current-weather-who={currentWeatherWho}>
    <section class="home-hero" aria-labelledby="homeTitle">
      <div class="home-avatar" aria-hidden="true">
        <img class="home-avatar__img" src="/assets/首页头像.png" alt="" />
      </div>
      <p class="home-kicker">Two little dogs, one little home</p>
      <h1 id="homeTitle">我们的小窝</h1>

      <div class="home-duo-status" aria-label="两个人的今日状态">
        <article class="home-status home-status--white">
          <img class="home-status__dog" src="/assets/小白首页形象.png" alt={`${whiteDisplayName}形象`} />
          <div class="home-status__info">
            <h2 data-status-name="white">{whiteDisplayName}</h2>
            <dl>
              <div>
                <dt>所在地天气</dt>
                <dd id="whiteWeather">所在地待设置 · 天气待同步</dd>
              </div>
              <div>
                <dt>今日心情</dt>
                <dd class="home-status__editable">
                  <span id="whiteMood">软乎乎地开心</span>
                  <button class="home-status__edit" type="button" data-who="white" data-field="mood" aria-label={`编辑${whiteDisplayName}今日心情`}>编辑</button>
                </dd>
              </div>
              <div>
                <dt>正在干什么</dt>
                <dd class="home-status__editable">
                  <span id="whiteDoing">整理今天的小记录</span>
                  <button class="home-status__edit" type="button" data-who="white" data-field="doing" aria-label={`编辑${whiteDisplayName}正在干什么`}>编辑</button>
                </dd>
              </div>
            </dl>
            <p class="home-status__quote" id="whiteQuote" data-who="white" role="button" tabindex="0" aria-label={`重新生成${whiteDisplayName}的一句话`}>今天也要把小事认真收好。</p>
          </div>
        </article>

        <article class="home-status home-status--brown">
          <div class="home-status__info">
            <h2 data-status-name="brown">{brownDisplayName}</h2>
            <dl>
              <div>
                <dt>所在地天气</dt>
                <dd id="brownWeather">所在地待设置 · 天气待同步</dd>
              </div>
              <div>
                <dt>今日心情</dt>
                <dd class="home-status__editable">
                  <span id="brownMood">精神满满</span>
                  <button class="home-status__edit" type="button" data-who="brown" data-field="mood" aria-label={`编辑${brownDisplayName}今日心情`}>编辑</button>
                </dd>
              </div>
              <div>
                <dt>正在干什么</dt>
                <dd class="home-status__editable">
                  <span id="brownDoing">计划下一次出门</span>
                  <button class="home-status__edit" type="button" data-who="brown" data-field="doing" aria-label={`编辑${brownDisplayName}正在干什么`}>编辑</button>
                </dd>
              </div>
            </dl>
            <p class="home-status__quote" id="brownQuote" data-who="brown" role="button" tabindex="0" aria-label={`重新生成${brownDisplayName}的一句话`}>先把想去的地方写下来，路会慢慢出现。</p>
          </div>
          <img class="home-status__dog" src="/assets/小棕首页形象.jpg" alt={`${brownDisplayName}形象`} />
        </article>
      </div>

      <p class="home-hero__text">
        一起写博客、存照片、记生活，也把每天不同时段发生的小事慢慢收进来。
      </p>
    </section>

    <section class="home-recent-photos" aria-labelledby="recentPhotosTitle">
      <h2 id="recentPhotosTitle">最近照片</h2>
      <div class="home-photo-stage" id="homeRecentPhotos" aria-live="polite">
        {displayPhotos.map((photo, index) => (
          <a class="home-photo-card" style={`--i:${index}`} href="/photos">
            <img src={photo.publicUrl} alt={photo.title || photo.caption || "照片"} loading="lazy" />
            <span class="home-photo-card__meta">
              <span>{photo.title || "一张小照片"}</span>
              <small>{photo.taken_on || photo.profiles?.display_name || "小窝"}</small>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-modules" aria-labelledby="modulesTitle">
      <h2 id="modulesTitle">Modules</h2>
      <div class="home-module-list">
        <a href="/records"><span>生活记录</span><small>心情、日记和当天照片</small></a>
        <a href="/photos"><span>照片墙</span><small>按日期整理的小相册</small></a>
        <a href="/blog"><span>双人博客</span><small>两个人一起写长文章</small></a>
        <a href="/activity"><span>时段活动</span><small>时间线和当日占比统计</small></a>
      </div>
    </section>

    <section class="home-places" aria-labelledby="placesTitle">
      <h2 id="placesTitle">Places</h2>
      <div class="home-places__body">
        <div class="home-places__head">
          <div>
            <p class="home-places__kicker">今年想去的地方</p>
            <p class="home-places__count" id="placeCount">{homePlaces.length} 个目的地</p>
          </div>
          <a class="home-places__toggle" href="/places">查看全部 →</a>
        </div>

        <div class="place-stage" id="placeList" aria-live="polite">
          {homePlaces.map((place) => (
            <article class={`place-card place-card--${place.tone}`} tabindex="0">
              <div class="place-card__art">
                <span class={place.tone === "night" ? "place-card__moon" : "place-card__sun"}></span>
                <span class="place-card__land"></span>
              </div>
              <div class="place-card__content">
                <h3 class="place-card__name">{place.name}</h3>
                <p class="place-card__note">{place.note}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-posts" aria-labelledby="postsTitle">
      <h2 id="postsTitle">Posts</h2>
      <div class="home-post-list">
        {recentPosts.length ? recentPosts.map((post) => (
          <a href={`/blog/${post.slug}`}>
            <time>{formatPostDate(post.published_at || post.created_at)}</time>
            <span>{post.title}</span>
          </a>
        )) : postFallbacks.map((post) => (
          <a href={post.href}>
            <time>{post.date}</time>
            <span>{post.title}</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Fragment slot="scripts">
    <script is:inline src="/scripts/cover.js"></script>
    <script is:inline src="/scripts/home.js"></script>
  </Fragment>
</PrototypeLayout>
